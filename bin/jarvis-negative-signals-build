#!/usr/bin/env python3
"""jarvis-negative-signals-build — agrège les rejets d'observations.md en signal exploitable.

Pour chaque entrée d'`observations.md` marquée `status: REJECTED <date> <raison>`, extrait :
- Le pattern rejeté (résumé en 1 ligne)
- Les mots-clés thématiques (premiers mots du pattern observé)
- La date du rejet
- La raison

Écrit `Memory/auto/_negative-signals.md` consommable par :
1. Le scoring quantitatif (Phase 2) — pénalité -0.30 si nouveau pattern proche d'un rejected
2. La routine eval — éviter de re-proposer un pattern déjà rejeté

Idempotent : ré-exécutable autant qu'on veut.

Usage :
  jarvis-negative-signals-build           # écrit
  jarvis-negative-signals-build --dry-run # affiche, n'écrit pas
"""
from __future__ import annotations

import argparse
import re
import sys
from datetime import datetime
from pathlib import Path

OBS = Path.home() / "Documents/Obsidian/vault/Claude/Memory/observations.md"
OUT = Path.home() / "Documents/Obsidian/vault/Claude/Memory/auto/_negative-signals.md"

# Une entrée d'observations.md commence par un frontmatter `---\n...\n---\n`
# suivi du contenu. On split sur `---` triple ou plus.
ENTRY_SPLIT_RE = re.compile(r"^---\s*$", re.MULTILINE)
REJECTED_RE = re.compile(r"^status:\s*REJECTED\s+(\d{4}-\d{2}-\d{2})(?:\s+(.+))?$", re.MULTILINE)
PATTERN_RE = re.compile(r"\*\*Pattern observé\*\*\s*:\s*(.+?)(?:\n|$)", re.DOTALL)
DATE_RE = re.compile(r"^date:\s*(\d{4}-\d{2}-\d{2})", re.MULTILINE)


def parse_observations(text: str) -> list[dict]:
    """Renvoie une liste de dicts par entrée REJECTED."""
    # Split par séparateurs `---` ; chaque entrée a alternance frontmatter/body
    blocks = ENTRY_SPLIT_RE.split(text)
    rejected: list[dict] = []
    # Heuristique simple : on regroupe par 2 (frontmatter + body suivant)
    # mais le format réel d'observations.md mélange ça. Plus robuste : itérer
    # par paires de "---" et chercher REJECTED dans chaque tranche.
    i = 0
    while i < len(blocks) - 1:
        chunk = blocks[i] + "\n---\n" + blocks[i + 1]
        rej = REJECTED_RE.search(chunk)
        if rej:
            pat_match = PATTERN_RE.search(chunk)
            date_match = DATE_RE.search(chunk)
            rejected.append({
                "rejected_on": rej.group(1),
                "reason": (rej.group(2) or "").strip(),
                "pattern": (pat_match.group(1).strip() if pat_match else "?"),
                "original_date": date_match.group(1) if date_match else "?",
            })
        i += 1
    return rejected


def render(rejected: list[dict]) -> str:
    now = datetime.now().strftime("%Y-%m-%d %H:%M")
    lines = [
        "# Memory/auto/_negative-signals.md",
        "",
        f"> Auto-généré par `jarvis-negative-signals-build` le {now}.",
        f"> {len(rejected)} pattern{'s' if len(rejected) != 1 else ''} rejeté{'s' if len(rejected) != 1 else ''} extraits d'`observations.md`.",
        "> Consommé par : scoring Phase 2 (pénalité −0.30 si nouveau pattern proche), routine eval (évite re-proposition).",
        "",
        "**Ne pas éditer** — régénéré quotidiennement par `jarvis-dream.sh` à 04h00 RE.",
        "",
        "---",
        "",
    ]

    if not rejected:
        lines.append("_Aucun pattern rejeté à ce jour._")
        return "\n".join(lines)

    # Trier par date de rejet décroissante
    rejected.sort(key=lambda x: x["rejected_on"], reverse=True)

    for r in rejected:
        lines.append(f"## Rejeté {r['rejected_on']}")
        lines.append("")
        lines.append(f"- **Pattern** : {r['pattern'][:200]}{'…' if len(r['pattern']) > 200 else ''}")
        lines.append(f"- **Observé initialement** : {r['original_date']}")
        if r["reason"]:
            lines.append(f"- **Raison du rejet** : {r['reason']}")
        lines.append("")

    # Bloc keywords pour matching rapide (utilisé par le scoring)
    lines.append("---")
    lines.append("")
    lines.append("## Keywords agrégés (pour matching scoring Phase 2)")
    lines.append("")
    lines.append("Liste des termes-clés extraits des patterns rejetés. Le scoring Phase 2 calcule un overlap entre ces keywords et le pattern courant pour appliquer la pénalité −0.30 si overlap ≥ 2 termes.")
    lines.append("")
    keywords: set[str] = set()
    for r in rejected:
        for word in re.findall(r"\b[a-zA-Zàâéèêëïîôöùûüç]{4,}\b", r["pattern"].lower()):
            if word not in {"pattern", "préfère", "valide", "demande", "indices",
                            "validé", "promouvoir", "version", "session", "prend", "veut",
                            "dans", "sans", "pour", "avec", "vers", "fois", "plus", "tout"}:
                keywords.add(word)
    if keywords:
        lines.append(", ".join(sorted(keywords)[:50]))  # cap à 50 pour éviter inflation
    else:
        lines.append("_Aucun keyword extrait._")

    return "\n".join(lines)


def main() -> int:
    p = argparse.ArgumentParser(description=__doc__.splitlines()[0])
    p.add_argument("--dry-run", action="store_true")
    args = p.parse_args()

    if not OBS.exists():
        print(f"⚠ observations.md introuvable : {OBS}", file=sys.stderr)
        return 1

    text = OBS.read_text(encoding="utf-8", errors="ignore")
    rejected = parse_observations(text)
    rendered = render(rejected)

    if args.dry_run:
        print(rendered)
        return 0

    OUT.parent.mkdir(parents=True, exist_ok=True)
    OUT.write_text(rendered, encoding="utf-8")
    print(f"✓ {OUT.name} régénéré : {len(rejected)} rejet(s) · {len(rendered):,} chars")
    return 0


if __name__ == "__main__":
    sys.exit(main())
