#!/bin/zsh
# jarvis-vault-index — Wrapper qui lance le scanner Python via le venv dédié.

set -uo pipefail

VENV="$HOME/.local/share/jarvis/venv"
SCRIPT="$HOME/.local/bin/jarvis-vault-index.py"
LOG="$HOME/.local/var/log/jarvis-vault-index.log"

mkdir -p "$(dirname "$LOG")"

if [[ ! -d "$VENV" ]]; then
  echo "❌ venv introuvable : $VENV" >&2
  echo "   Reproduire le setup :" >&2
  echo "   /opt/homebrew/bin/python3.13 -m venv $VENV" >&2
  echo "   $VENV/bin/pip install sqlite-vec sentence-transformers numpy" >&2
  exit 1
fi

if [[ ! -f "$SCRIPT" ]]; then
  echo "❌ Script Python manquant : $SCRIPT" >&2
  echo "   Relancer : ~/Documents/GIT\\ PROD/manin-jarvis/bootstrap.sh" >&2
  exit 1
fi

exec "$VENV/bin/python" "$SCRIPT" "$@"
