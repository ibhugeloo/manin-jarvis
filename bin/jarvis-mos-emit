#!/bin/zsh
# jarvis-mos-emit — helper pour les hooks Claude Code.
#
# Lit un payload JSON Claude Code sur stdin, en extrait les champs utiles
# et les POST vers MOS /events en best-effort (silent-fail si daemon down).
#
# Usage : printf '%s' "$INPUT_JSON" | jarvis-mos-emit <hook_name> [tool_name]
#
# Exemples :
#   printf '%s' "$INPUT" | jarvis-mos-emit UserPromptSubmit
#   printf '%s' "$INPUT" | jarvis-mos-emit PreToolUse "$TOOL_NAME"
#   printf '%s' "$INPUT" | jarvis-mos-emit SessionEnd
#
# Conçu pour être appelé en parallèle de la logique métier des hooks ; ne casse
# JAMAIS la chaîne (timeout 1s, exit 0 systématique).

set -uo pipefail

HOOK="${1:-UnknownHook}"
TOOL="${2:-}"

API="${MOS_API:-http://127.0.0.1:${MOS_PORT:-3737}}"

INPUT=$(cat 2>/dev/null || true)

# Build payload via jq ; fallback minimal si jq plante ou input non-JSON.
PAYLOAD=$(printf '%s' "$INPUT" | jq -c \
  --arg hook "$HOOK" \
  --arg tool "$TOOL" \
  '{
    hook: $hook,
    tool: ($tool | select(. != "")),
    session_id: (.session_id // null),
    cwd: (.cwd // null),
    payload: {
      tool_name: (.tool_name // null),
      tool_input_keys: ((.tool_input // {}) | keys),
      prompt_len: ((.prompt // "") | length),
      stop_hook_active: (.stop_hook_active // null)
    }
  }' 2>/dev/null) || PAYLOAD=""

if [[ -z "$PAYLOAD" ]]; then
  PAYLOAD="{\"hook\":\"$HOOK\",\"payload\":{\"jq_failed\":true}}"
fi

curl --silent --max-time 1 --output /dev/null \
  -X POST "$API/events" \
  -H 'Content-Type: application/json' \
  -d "$PAYLOAD" 2>/dev/null || true

exit 0
