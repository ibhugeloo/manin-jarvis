#!/bin/zsh
# jarvis-notify — Envoie un message Telegram à le boss.
# Usage : jarvis-notify "<message>" [--silent] [--markdown]
#         echo "msg" | jarvis-notify
#
# Lit le token + chat_id depuis ~/.config/jarvis/telegram.env

set -uo pipefail

ENV_FILE="$HOME/.config/jarvis/telegram.env"
LOG="$HOME/.local/var/log/jarvis-notify.log"

mkdir -p "$(dirname "$LOG")"

# Lire le message depuis args ou stdin
SILENT=false
PARSE_MODE=""
ARGS=()

for arg in "$@"; do
  case "$arg" in
    --silent) SILENT=true ;;
    --markdown) PARSE_MODE="Markdown" ;;
    --html) PARSE_MODE="HTML" ;;
    *) ARGS+=("$arg") ;;
  esac
done

if [[ ${#ARGS[@]} -gt 0 ]]; then
  MSG="${ARGS[*]}"
elif [[ ! -t 0 ]]; then
  MSG=$(cat)
else
  echo "Usage: jarvis-notify \"<message>\" [--silent] [--markdown]" >&2
  exit 1
fi

if [[ -z "${MSG// }" ]]; then
  echo "[!] Message vide, abandon" >&2
  exit 1
fi

if [[ ! -f "$ENV_FILE" ]]; then
  echo "[!] Config Telegram absente : $ENV_FILE" >&2
  echo "    Lancer : jarvis-telegram-setup" >&2
  exit 1
fi

# shellcheck disable=SC1090
source "$ENV_FILE"

if [[ -z "${BOT_TOKEN:-}" || -z "${CHAT_ID:-}" ]]; then
  echo "[!] BOT_TOKEN ou CHAT_ID absent dans $ENV_FILE" >&2
  exit 1
fi

# Tronquer si > 4000 chars (limite Telegram = 4096)
if [[ ${#MSG} -gt 4000 ]]; then
  MSG="${MSG:0:3950}…
[message tronqué — voir logs locaux]"
fi

# Construire la requête
DATA=(
  --data-urlencode "chat_id=$CHAT_ID"
  --data-urlencode "text=$MSG"
  --data-urlencode "disable_notification=$SILENT"
)
[[ -n "$PARSE_MODE" ]] && DATA+=(--data-urlencode "parse_mode=$PARSE_MODE")

RESPONSE=$(curl -sS -m 15 \
  "https://api.telegram.org/bot$BOT_TOKEN/sendMessage" \
  "${DATA[@]}" 2>&1)

OK=$(echo "$RESPONSE" | jq -r '.ok // false' 2>/dev/null)

if [[ "$OK" == "true" ]]; then
  echo "[$(date)] OK — ${#MSG} chars" >> "$LOG"
  exit 0
else
  echo "[$(date)] FAIL — $RESPONSE" >> "$LOG"
  echo "[!] Échec envoi Telegram, voir $LOG" >&2
  exit 1
fi
