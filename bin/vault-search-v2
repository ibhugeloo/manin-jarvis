#!/bin/zsh
# vault-search-v2 — Recherche sémantique vraie (sqlite-vec + sentence-transformers).
# Usage : vault-search-v2 "<question>" [-k 10]

set -uo pipefail

VENV="$HOME/.local/share/jarvis/venv"
SCRIPT="$HOME/.local/bin/vault-search-v2.py"

if [[ ! -d "$VENV" ]]; then
  echo "❌ venv introuvable : $VENV. Lancez bootstrap." >&2
  exit 1
fi

if [[ ! -f "$SCRIPT" ]]; then
  echo "❌ Script Python manquant : $SCRIPT (devrait être copié par bootstrap)." >&2
  exit 1
fi

if [[ $# -eq 0 ]]; then
  cat <<EOF
Usage: vault-search-v2 "<question en langage naturel>" [-k N]

Exemples :
  vault-search-v2 "ma stratégie d'allocation PEA"
  vault-search-v2 "trail à Mafate" -k 5
  vault-search-v2 "comment je gère mon homelab"

Diffère de vault-search V1 (query expansion + grep) : ici similarité sémantique
via embeddings locaux. Trouve des concepts liés même avec une formulation différente.

Réindex : jarvis-vault-index (cron quotidien automatique)
Stats   : jarvis-vault-index --stats
EOF
  exit 1
fi

exec "$VENV/bin/python" "$SCRIPT" "$@"
