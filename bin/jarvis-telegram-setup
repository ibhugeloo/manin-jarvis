#!/bin/zsh
# jarvis-telegram-setup — Configuration interactive du bot Telegram.
#
# Étapes :
#  1. Création du bot via @BotFather (manuel, par le boss)
#  2. Saisie du BOT_TOKEN
#  3. Détection automatique du CHAT_ID
#  4. Test d'envoi
#  5. Écriture du fichier env

set -euo pipefail

CONFIG_DIR="$HOME/.config/jarvis"
ENV_FILE="$CONFIG_DIR/telegram.env"

mkdir -p "$CONFIG_DIR"
chmod 700 "$CONFIG_DIR"

if [[ -t 1 ]]; then
  R=$'\033[31m'; G=$'\033[32m'; Y=$'\033[33m'; B=$'\033[34m'; D=$'\033[2m'; N=$'\033[0m'
else
  R=""; G=""; Y=""; B=""; D=""; N=""
fi

echo ""
echo "${B}═══════════════════════════════════════════════════════════════${N}"
echo "${B}   Jarvis — Setup bot Telegram${N}"
echo "${B}═══════════════════════════════════════════════════════════════${N}"
echo ""
echo "${D}Étape 1/4 — Créer un bot Telegram :${N}"
echo "  1. Ouvrir Telegram et chercher ${B}@BotFather${N}"
echo "  2. Envoyer ${B}/newbot${N}"
echo "  3. Choisir un nom (ex: Jarvis le boss)"
echo "  4. Choisir un username unique (ex: yourname_jarvis_bot)"
echo "  5. Copier le ${B}token${N} (format : 123456789:ABCdef...)"
echo ""
read "BOT_TOKEN?Token du bot : "

if [[ -z "${BOT_TOKEN// }" ]]; then
  echo "${R}❌ Token vide, abandon.${N}" >&2
  exit 1
fi

# Validation du token (format simple)
if [[ ! "$BOT_TOKEN" =~ ^[0-9]+:[A-Za-z0-9_-]+$ ]]; then
  echo "${Y}⚠ Format inhabituel — on continue quand même.${N}"
fi

echo ""
echo "${D}Étape 2/4 — Vérifier le bot...${N}"
ME=$(curl -sS -m 10 "https://api.telegram.org/bot$BOT_TOKEN/getMe")
BOT_USERNAME=$(echo "$ME" | jq -r '.result.username // empty')

if [[ -z "$BOT_USERNAME" ]]; then
  echo "${R}❌ Token invalide. Réponse Telegram :${N}"
  echo "$ME" | jq '.' 2>/dev/null || echo "$ME"
  exit 1
fi

echo "${G}✓${N} Bot trouvé : @$BOT_USERNAME"

echo ""
echo "${D}Étape 3/4 — Détecter votre chat ID :${N}"
echo "  1. Ouvrir Telegram"
echo "  2. Chercher ${B}@$BOT_USERNAME${N}"
echo "  3. Lui envoyer ${B}/start${N} (puis n'importe quel message)"
echo ""
echo "${Y}Quand c'est fait, appuyez sur ${B}Entrée${N}${Y} ici...${N}"
read -r _

echo "${D}Récupération des updates...${N}"
UPDATES=$(curl -sS -m 10 "https://api.telegram.org/bot$BOT_TOKEN/getUpdates")
CHAT_ID=$(echo "$UPDATES" | jq -r '[.result[] | .message.chat.id] | unique | .[0] // empty')

if [[ -z "$CHAT_ID" || "$CHAT_ID" == "null" ]]; then
  echo "${R}❌ Aucun message reçu. Vérifiez que vous avez bien envoyé un message au bot, puis re-lancer ce script.${N}"
  exit 1
fi

CHAT_NAME=$(echo "$UPDATES" | jq -r '[.result[] | .message.from] | unique_by(.id) | .[] | select(.id=='$CHAT_ID') | "\(.first_name // "") \(.last_name // "") (@\(.username // "?"))"' | head -1)

echo "${G}✓${N} Chat ID détecté : ${B}$CHAT_ID${N} ($CHAT_NAME)"

echo ""
echo "${D}Étape 4/4 — Test d'envoi...${N}"
TEST_RESP=$(curl -sS -m 10 \
  "https://api.telegram.org/bot$BOT_TOKEN/sendMessage" \
  --data-urlencode "chat_id=$CHAT_ID" \
  --data-urlencode "text=✅ Jarvis configuré, boss. Vous pouvez me parler depuis ce chat. Tapez /help pour les commandes.")

TEST_OK=$(echo "$TEST_RESP" | jq -r '.ok // false')
if [[ "$TEST_OK" != "true" ]]; then
  echo "${R}❌ Échec envoi test :${N}"
  echo "$TEST_RESP" | jq '.' 2>/dev/null || echo "$TEST_RESP"
  exit 1
fi

# Écriture du fichier env
cat > "$ENV_FILE" <<EOF
# Jarvis Telegram bot — configuration générée le $(date)
BOT_TOKEN="$BOT_TOKEN"
BOT_USERNAME="$BOT_USERNAME"
CHAT_ID="$CHAT_ID"
EOF

chmod 600 "$ENV_FILE"

echo "${G}✓${N} Configuration écrite : $ENV_FILE"
echo ""
echo "${G}═══════════════════════════════════════════════════════════════${N}"
echo "${G}  Setup terminé.${N}"
echo "${G}═══════════════════════════════════════════════════════════════${N}"
echo ""
echo "${B}Prochaines étapes :${N}"
echo "  1. Re-lancer le bootstrap pour activer le LaunchAgent du bot :"
echo "     ${D}~/Documents/Obsidian/vault/Claude/Jarvis/bootstrap.sh${N}"
echo ""
echo "  2. Tester l'envoi d'une notif :"
echo "     ${D}jarvis-notify \"Hello, boss\"${N}"
echo ""
echo "  3. Tester le bot conversationnel : envoyer un message au bot Telegram."
echo ""
