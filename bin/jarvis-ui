#!/bin/zsh
# jarvis-ui — Lance le dashboard local et ouvre le navigateur
# Usage : jarvis-ui [--no-open] [--port N]

set -uo pipefail

PORT=7474
OPEN=1

for arg in "$@"; do
  case "$arg" in
    --no-open) OPEN=0 ;;
    --port=*) PORT="${arg#--port=}" ;;
    --port)
      shift
      PORT="$1"
      ;;
  esac
done

PYTHON="${PYTHON:-/usr/bin/python3}"
SCRIPT="$HOME/.local/bin/jarvis-ui-server.py"

if [[ ! -f "$SCRIPT" ]]; then
  echo "❌ jarvis-ui-server.py introuvable à $SCRIPT — lancez bootstrap.sh" >&2
  exit 1
fi

# Si déjà en cours, juste ouvrir le navigateur
if lsof -i ":$PORT" -sTCP:LISTEN >/dev/null 2>&1; then
  echo "Dashboard déjà actif sur le port $PORT"
  [[ "$OPEN" -eq 1 ]] && open "http://localhost:$PORT"
  exit 0
fi

# Lancer en background
nohup "$PYTHON" "$SCRIPT" --port "$PORT" > "$HOME/.local/var/log/jarvis-ui.log" 2>&1 &
PID=$!
echo "Dashboard lancé sur http://localhost:$PORT (pid $PID)"
sleep 1

[[ "$OPEN" -eq 1 ]] && open "http://localhost:$PORT"
