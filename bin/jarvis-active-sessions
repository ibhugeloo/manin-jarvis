#!/usr/bin/env python3
"""jarvis-active-sessions — registre des sessions Claude Code actives.

État : ~/.jarvis/active-sessions.json (array d'objets {session_id, cwd, started_at, last_activity}).
Concurrence : verrou via fcntl.flock sur le fichier d'état.

Sous-commandes :
  register        Lit JSON hook sur stdin → ajoute/rafraîchit l'entrée
  touch           Lit JSON hook sur stdin → update last_activity
  unregister      Lit JSON hook sur stdin → retire l'entrée
  list-others     Lit JSON hook sur stdin → JSON array des autres sessions fraîches (<30 min)
  format-context  Lit JSON hook sur stdin → markdown additionalContext (vide si rien)
  prune           Nettoie les entrées dépassant le TTL (8h sans activité)

Tous les hooks Claude Code passent un JSON sur stdin contenant au minimum
`session_id`, `cwd`, `transcript_path`. On lit ces champs.
"""
from __future__ import annotations

import datetime as dt
import fcntl
import json
import os
import pathlib
import sys

STATE_DIR = pathlib.Path.home() / ".jarvis"
STATE_FILE = STATE_DIR / "active-sessions.json"
FRESHNESS_MIN = 30   # une session est "active" si last_activity < 30 min
TTL_HOURS = 8        # prune les entrées dépassant ce délai


def _now() -> str:
    return dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def _parse_iso(ts: str) -> dt.datetime:
    return dt.datetime.strptime(ts, "%Y-%m-%dT%H:%M:%SZ").replace(tzinfo=dt.timezone.utc)


def _read_input() -> dict:
    """Lit le JSON envoyé par Claude Code sur stdin. Tolérant aux entrées vides."""
    raw = sys.stdin.read().strip()
    if not raw:
        return {}
    try:
        return json.loads(raw)
    except json.JSONDecodeError:
        return {}


def _open_state():
    """Ouvre le fichier d'état avec un verrou exclusif. Retourne (file, data)."""
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    if not STATE_FILE.exists():
        STATE_FILE.write_text('{"sessions": []}')
    f = STATE_FILE.open("r+")
    fcntl.flock(f.fileno(), fcntl.LOCK_EX)
    try:
        data = json.loads(f.read() or '{"sessions": []}')
    except json.JSONDecodeError:
        data = {"sessions": []}
    return f, data


def _write_state(f, data: dict) -> None:
    f.seek(0)
    f.truncate()
    json.dump(data, f, indent=2)
    f.write("\n")
    f.flush()
    fcntl.flock(f.fileno(), fcntl.LOCK_UN)
    f.close()


def _prune(data: dict) -> dict:
    cutoff = dt.datetime.now(dt.timezone.utc) - dt.timedelta(hours=TTL_HOURS)
    kept = []
    for s in data.get("sessions", []):
        try:
            last = _parse_iso(s.get("last_activity", s.get("started_at", "")))
            if last >= cutoff:
                kept.append(s)
        except (ValueError, TypeError):
            continue
    data["sessions"] = kept
    return data


def cmd_register(payload: dict) -> int:
    sid = payload.get("session_id", "")
    cwd = payload.get("cwd", os.getcwd())
    if not sid:
        return 0
    f, data = _open_state()
    data = _prune(data)
    sessions = [s for s in data["sessions"] if s.get("session_id") != sid]
    sessions.append({
        "session_id": sid,
        "cwd": cwd,
        "started_at": _now(),
        "last_activity": _now(),
    })
    data["sessions"] = sessions
    _write_state(f, data)
    return 0


def cmd_touch(payload: dict) -> int:
    sid = payload.get("session_id", "")
    if not sid:
        return 0
    f, data = _open_state()
    data = _prune(data)
    found = False
    for s in data["sessions"]:
        if s.get("session_id") == sid:
            s["last_activity"] = _now()
            found = True
    if not found:
        # auto-register si la session n'a pas été enregistrée (ex: hook SessionStart raté)
        data["sessions"].append({
            "session_id": sid,
            "cwd": payload.get("cwd", os.getcwd()),
            "started_at": _now(),
            "last_activity": _now(),
        })
    _write_state(f, data)
    return 0


def cmd_unregister(payload: dict) -> int:
    sid = payload.get("session_id", "")
    if not sid:
        return 0
    f, data = _open_state()
    data["sessions"] = [s for s in data["sessions"] if s.get("session_id") != sid]
    _write_state(f, data)
    return 0


def _fresh_others(payload: dict) -> list[dict]:
    sid = payload.get("session_id", "")
    f, data = _open_state()
    data = _prune(data)
    cutoff = dt.datetime.now(dt.timezone.utc) - dt.timedelta(minutes=FRESHNESS_MIN)
    others = []
    for s in data["sessions"]:
        if s.get("session_id") == sid:
            continue
        try:
            last = _parse_iso(s.get("last_activity", ""))
        except (ValueError, TypeError):
            continue
        if last >= cutoff:
            others.append(s)
    _write_state(f, data)  # data inchangée mais on relâche le lock proprement
    return others


def cmd_list_others(payload: dict) -> int:
    print(json.dumps(_fresh_others(payload), indent=2))
    return 0


def cmd_format_context(payload: dict) -> int:
    """Génère un markdown lisible des autres sessions actives, ou silence."""
    others = _fresh_others(payload)
    if not others:
        return 0
    lines = ["## Sessions Claude Code actives en parallèle",
             "",
             "Une ou plusieurs autres sessions tournent en ce moment. Avant de classer une modif non-commitée comme \"orpheline\", vérifie qu'elle ne provient pas d'une de ces sessions :",
             ""]
    for s in others:
        cwd = s.get("cwd", "?")
        started = s.get("started_at", "?")
        last = s.get("last_activity", "?")
        sid = s.get("session_id", "")[:8]
        lines.append(f"- **{cwd}** — session `{sid}…` — démarrée {started}, dernière activité {last}")
    lines.append("")
    lines.append("Source : `~/.jarvis/active-sessions.json` (cf. `feedback_sessions_paralleles.md`).")
    print("\n".join(lines))
    return 0


def cmd_prune(_: dict) -> int:
    f, data = _open_state()
    before = len(data.get("sessions", []))
    data = _prune(data)
    after = len(data["sessions"])
    _write_state(f, data)
    print(f"prune: {before} → {after}")
    return 0


COMMANDS = {
    "register": cmd_register,
    "touch": cmd_touch,
    "unregister": cmd_unregister,
    "list-others": cmd_list_others,
    "format-context": cmd_format_context,
    "prune": cmd_prune,
}


def main() -> int:
    if len(sys.argv) < 2 or sys.argv[1] not in COMMANDS:
        print(f"usage: {sys.argv[0]} {{{','.join(COMMANDS)}}}", file=sys.stderr)
        return 2
    payload = _read_input()
    return COMMANDS[sys.argv[1]](payload)


if __name__ == "__main__":
    sys.exit(main())
