#!/usr/bin/env python3
"""jarvis-msg — boîte aux lettres asynchrone entre sessions Claude Code.

Stockage : ~/.jarvis/inbox/<session_id>/{pending,_read}/<timestamp>-<from>.md
Format : frontmatter YAML (from, from_cwd, sent_at) + corps markdown.

Sous-commandes :
  send <to> <message>   Envoie un message. <to> ∈ {session_id court (8c), cwd partiel, "other"}.
                        Lit le session_id émetteur depuis JARVIS_FROM_SESSION ou stdin JSON.
  list                  Liste les messages en attente pour la session courante (lit JSON stdin).
  read                  Affiche et archive les messages en attente (lit JSON stdin).
  format-context        Génère le markdown additionalContext (silence si rien).
  sessions              Liste les sessions actives résolvables comme cibles.
  cleanup               Supprime les inbox des sessions plus présentes dans le registre.

Lecture du registre des sessions : ~/.jarvis/active-sessions.json (lecture seule).
"""
from __future__ import annotations

import datetime as dt
import json
import os
import pathlib
import re
import shutil
import sys

JARVIS_DIR = pathlib.Path.home() / ".jarvis"
INBOX_DIR = JARVIS_DIR / "inbox"
REGISTRY_FILE = JARVIS_DIR / "active-sessions.json"


def _now_iso() -> str:
    return dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def _now_filename() -> str:
    return dt.datetime.now(dt.timezone.utc).strftime("%Y%m%dT%H%M%SZ")


def _read_input() -> dict:
    raw = sys.stdin.read().strip()
    if not raw:
        return {}
    try:
        return json.loads(raw)
    except json.JSONDecodeError:
        return {}


def _load_registry() -> list[dict]:
    if not REGISTRY_FILE.exists():
        return []
    try:
        return json.loads(REGISTRY_FILE.read_text()).get("sessions", [])
    except (json.JSONDecodeError, OSError):
        return []


def _resolve_target(to: str, from_sid: str) -> str | None:
    """Résout l'argument <to> en session_id complet."""
    sessions = _load_registry()
    others = [s for s in sessions if s.get("session_id") != from_sid]

    if to == "other":
        if len(others) == 1:
            return others[0]["session_id"]
        if not others:
            print("erreur: aucune autre session active", file=sys.stderr)
        else:
            print(f"erreur: 'other' ambigu — {len(others)} sessions actives", file=sys.stderr)
            for s in others:
                print(f"  {s['session_id'][:8]}  {s.get('cwd', '?')}", file=sys.stderr)
        return None

    # 1) match par préfixe de session_id
    by_id = [s for s in others if s.get("session_id", "").startswith(to)]
    if len(by_id) == 1:
        return by_id[0]["session_id"]
    if len(by_id) > 1:
        print(f"erreur: préfixe '{to}' ambigu — {len(by_id)} matches", file=sys.stderr)
        for s in by_id:
            print(f"  {s['session_id'][:16]}…  {s.get('cwd', '?')}", file=sys.stderr)
        return None

    # 2) match par cwd substring
    by_cwd = [s for s in others if to in s.get("cwd", "")]
    if len(by_cwd) == 1:
        return by_cwd[0]["session_id"]
    if len(by_cwd) > 1:
        print(f"erreur: cwd partiel '{to}' ambigu — {len(by_cwd)} matches", file=sys.stderr)
        for s in by_cwd:
            print(f"  {s['session_id'][:8]}  {s.get('cwd', '?')}", file=sys.stderr)
        return None

    print(f"erreur: aucune session ne correspond à '{to}'", file=sys.stderr)
    return None


def _from_session(payload: dict) -> tuple[str, str]:
    """Détermine l'émetteur. Priorité : env JARVIS_FROM_SESSION, sinon payload stdin."""
    sid = os.environ.get("JARVIS_FROM_SESSION", payload.get("session_id", ""))
    cwd = os.environ.get("JARVIS_FROM_CWD", payload.get("cwd", os.getcwd()))
    return sid, cwd


def cmd_send(payload: dict) -> int:
    if len(sys.argv) < 4:
        print("usage: jarvis-msg send <to> <message>", file=sys.stderr)
        return 2
    to_arg = sys.argv[2]
    message = " ".join(sys.argv[3:])

    from_sid, from_cwd = _from_session(payload)
    if not from_sid:
        print("erreur: session émettrice inconnue (JARVIS_FROM_SESSION ou stdin JSON requis)", file=sys.stderr)
        return 2

    target = _resolve_target(to_arg, from_sid)
    if not target:
        return 1

    pending = INBOX_DIR / target / "pending"
    pending.mkdir(parents=True, exist_ok=True)
    fname = f"{_now_filename()}-{from_sid[:8]}.md"
    body = (
        f"---\n"
        f"from: {from_sid}\n"
        f"from_cwd: {from_cwd}\n"
        f"sent_at: {_now_iso()}\n"
        f"---\n\n"
        f"{message}\n"
    )
    (pending / fname).write_text(body)
    print(f"envoyé → {target[:8]} ({fname})")
    return 0


def _pending_files(sid: str) -> list[pathlib.Path]:
    p = INBOX_DIR / sid / "pending"
    if not p.exists():
        return []
    return sorted(p.glob("*.md"))


def cmd_list(payload: dict) -> int:
    sid = payload.get("session_id", "")
    files = _pending_files(sid)
    print(f"{len(files)} message(s) en attente pour {sid[:8] if sid else '?'}")
    for f in files:
        print(f"  {f.name}")
    return 0


def _archive(sid: str, files: list[pathlib.Path]) -> None:
    archive = INBOX_DIR / sid / "_read"
    archive.mkdir(parents=True, exist_ok=True)
    for f in files:
        shutil.move(str(f), str(archive / f.name))


def cmd_read(payload: dict) -> int:
    """Lit et archive. Affiche le contenu brut (frontmatter + corps)."""
    sid = payload.get("session_id", "")
    if not sid:
        return 0
    files = _pending_files(sid)
    if not files:
        print("(aucun message)")
        return 0
    for f in files:
        print(f"=== {f.name} ===")
        print(f.read_text())
    _archive(sid, files)
    return 0


def _parse_msg(text: str) -> dict:
    """Parse un fichier markdown frontmatter YAML simple."""
    m = re.match(r"^---\n(.*?)\n---\n\n?(.*)$", text, re.DOTALL)
    if not m:
        return {"body": text}
    head, body = m.groups()
    meta = {}
    for line in head.splitlines():
        if ":" in line:
            k, v = line.split(":", 1)
            meta[k.strip()] = v.strip()
    meta["body"] = body.rstrip()
    return meta


def cmd_format_context(payload: dict) -> int:
    """Pour hook UserPromptSubmit. Génère markdown si messages, sinon silence."""
    sid = payload.get("session_id", "")
    if not sid:
        return 0
    files = _pending_files(sid)
    if not files:
        return 0

    lines = ["## Messages reçus d'autres sessions Claude Code", ""]
    for f in files:
        msg = _parse_msg(f.read_text())
        from_short = (msg.get("from", "?")[:8])
        from_cwd = msg.get("from_cwd", "?")
        sent_at = msg.get("sent_at", "?")
        lines.append(f"### De `{from_short}…` (cwd : {from_cwd}) — {sent_at}")
        lines.append("")
        lines.append(msg.get("body", "").strip())
        lines.append("")
    lines.append("---")
    lines.append("Ces messages ont été archivés. Pour répondre, utilise `jarvis-msg send <session_id_court ou \"other\"> \"<réponse>\"` (la session émettrice est dans le titre ci-dessus).")

    print("\n".join(lines))
    _archive(sid, files)
    return 0


def cmd_sessions(_: dict) -> int:
    sessions = _load_registry()
    if not sessions:
        print("(aucune session active)")
        return 0
    for s in sessions:
        print(f"  {s['session_id'][:8]}  {s.get('cwd', '?')}  (last_activity: {s.get('last_activity', '?')})")
    return 0


def cmd_cleanup(_: dict) -> int:
    if not INBOX_DIR.exists():
        return 0
    active_ids = {s.get("session_id") for s in _load_registry()}
    removed = 0
    for d in INBOX_DIR.iterdir():
        if d.is_dir() and d.name not in active_ids:
            shutil.rmtree(d)
            removed += 1
    print(f"cleanup: {removed} inbox(es) supprimée(s)")
    return 0


COMMANDS = {
    "send": cmd_send,
    "list": cmd_list,
    "read": cmd_read,
    "format-context": cmd_format_context,
    "sessions": cmd_sessions,
    "cleanup": cmd_cleanup,
}


def main() -> int:
    if len(sys.argv) < 2 or sys.argv[1] not in COMMANDS:
        print(f"usage: {sys.argv[0]} {{{','.join(COMMANDS)}}}", file=sys.stderr)
        return 2
    payload = _read_input() if not sys.stdin.isatty() else {}
    return COMMANDS[sys.argv[1]](payload)


if __name__ == "__main__":
    sys.exit(main())
