#!/usr/bin/env python3
"""jarvis-skills-bundle — régénère `Memory/auto/_index.md`, l'index léger des skills auto-promus.

Pattern inspiré Hermes : les skills auto-écrits par la routine eval (et hook session-recap)
vivent dans `Memory/auto/<date>-<slug>.md`. Pour qu'ils soient effectivement utiles à
Jarvis sans gonfler le contexte de démarrage, on auto-load uniquement un **index** —
listing avec frontmatter (description, type, occurrences, date) + un pointeur fichier.

Quand Jarvis détecte qu'un skill est pertinent (description matche le contexte), il
lit le fichier complet à la demande.

Usage :
  jarvis-skills-bundle             # écrit Memory/auto/_index.md
  jarvis-skills-bundle --dry-run   # affiche, n'écrit pas

Régénéré par :
  - LaunchAgent com.example.jarvis.vault-index-build à 7h30 (depuis 2026-06-04 ; ex-jarvis-brief.sh, supprimé le 2026-05-14)
  - Routine eval après auto-écriture d'un nouveau skill
  - Manuellement quand on archive/ajoute un skill
"""
from __future__ import annotations

import argparse
import re
import sys
from datetime import datetime
from pathlib import Path

AUTO_DIR = Path.home() / "Documents/Obsidian/vault/Claude/Memory/auto"
INDEX_PATH = AUTO_DIR / "_index.md"

# Frontmatter YAML simple : --- ... ---
FRONTMATTER_RE = re.compile(r"^---\s*\n(.*?)\n---\s*\n", re.DOTALL)
# Lignes "key: value" dans le frontmatter
KV_RE = re.compile(r"^([a-zA-Z_]+)\s*:\s*(.+?)\s*$", re.MULTILINE)


def parse_frontmatter(text: str) -> dict[str, str]:
    """Renvoie le frontmatter YAML d'un skill markdown sous forme de dict."""
    m = FRONTMATTER_RE.match(text)
    if not m:
        return {}
    return {k: v.strip() for k, v in KV_RE.findall(m.group(1))}


def collect_skills() -> list[tuple[Path, dict[str, str], str]]:
    """Renvoie [(path, frontmatter_dict, fallback_first_h1)] pour chaque skill auto."""
    skills: list[tuple[Path, dict[str, str], str]] = []
    if not AUTO_DIR.exists():
        return skills
    for md in sorted(AUTO_DIR.glob("*.md")):
        if md.name.startswith("_"):
            continue  # Skip _index.md lui-même + autres fichiers méta
        try:
            text = md.read_text(encoding="utf-8", errors="ignore")
        except OSError:
            continue
        fm = parse_frontmatter(text)
        # Fallback : premier H1 si pas de description dans le frontmatter
        body = FRONTMATTER_RE.sub("", text, count=1)
        h1_match = re.search(r"^#\s+(.+?)\s*$", body, re.MULTILINE)
        first_h1 = h1_match.group(1).strip() if h1_match else md.stem
        skills.append((md, fm, first_h1))
    return skills


def render(skills: list[tuple[Path, dict[str, str], str]]) -> str:
    now = datetime.now().strftime("%Y-%m-%d %H:%M")
    lines: list[str] = [
        "# Memory/auto/ — index des skills auto-promus",
        "",
        f"> Auto-généré par `jarvis-skills-bundle` le {now}.",
        f"> {len(skills)} skill{'s' if len(skills) != 1 else ''} auto-écrits par routine eval ou hook session-recap.",
        "> **Ne pas éditer** — régénéré à 7h30 par le LaunchAgent `vault-index-build`.",
        "",
        "Patterns détectés automatiquement (3+ occurrences sur fenêtre 5j ou cluster confidence:high d'observations).",
        "Pas de validation préalable — review au cycle eval suivant pour purge si jamais déclenché.",
        "",
        "Pour utiliser un skill : lire le fichier `Memory/auto/<filename>.md` quand sa **description** matche le contexte courant.",
        "",
        "---",
        "",
    ]

    if not skills:
        lines.append("_Aucun skill auto-promu pour l'instant._")
        return "\n".join(lines)

    for path, fm, first_h1 in skills:
        name = fm.get("name", path.stem)
        description = fm.get("description", first_h1)
        skill_type = fm.get("type", "?")
        occurrences = fm.get("occurrences", "?")
        generated_on = fm.get("generated_on", path.stem.split("-", 3)[:3])
        if isinstance(generated_on, list):
            generated_on = "-".join(generated_on)
        status = fm.get("status", "active")

        lines.append(f"### `{path.name}` — {name}")
        lines.append(f"- **Description** : {description}")
        lines.append(
            f"- **Type** : {skill_type} · **Occurrences** : {occurrences} · "
            f"**Généré** : {generated_on} · **Status** : {status}"
        )
        lines.append("")

    return "\n".join(lines)


def main() -> int:
    p = argparse.ArgumentParser(description=__doc__.splitlines()[0])
    p.add_argument("--dry-run", action="store_true")
    args = p.parse_args()

    skills = collect_skills()
    rendered = render(skills)

    if args.dry_run:
        print(rendered)
        return 0

    AUTO_DIR.mkdir(parents=True, exist_ok=True)
    INDEX_PATH.write_text(rendered, encoding="utf-8")
    print(f"✓ {INDEX_PATH.name} régénéré : {len(skills)} skill(s) · {len(rendered):,} chars")
    return 0


if __name__ == "__main__":
    sys.exit(main())
