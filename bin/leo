#!/usr/bin/env bash
# leo — second avis via Hermes/Leo (GPT-5.5, self-hosted homelab).
#   Leo = pair de Jarvis, cerveau non-Claude (lignée OpenAI). Persona/SOUL chargée
#   côté Hermes (/root/.hermes/SOUL.md). Tourne dans le LXC <your-lxc-id> (hermes,
#   <llm-lxc-ip>) sur Srv1. Mémoire persistante : Leo apprend au fil des sessions.
#
#   Fallback Codex (ancien wrapper) : ~/.local/bin/leo-codex
#
# Usage:
#   leo "<question>"
#   leo --context FILE "<question>"     (ou -c)
#   leo --deep "<question>"             (ou -d)  -> analyse approfondie
set -eo pipefail

KEY="$HOME/.ssh/<your-homelab-key>"
PVE="root@<homelab-host>"
CTID="<your-lxc-id>"

CONTEXT_FILE=""
DEEP=0
QUESTION=""

usage() { echo 'leo — second avis via Hermes/Leo (GPT-5.5)
Usage: leo [-c|--context FILE] [-d|--deep] "<question>"
  (fallback Codex : leo-codex)' >&2; }

while [ $# -gt 0 ]; do
  case "$1" in
    -c|--context) CONTEXT_FILE="$2"; shift 2;;
    -d|--deep)    DEEP=1; shift;;
    -m|--model|--provider) shift 2;;   # ignorés : Hermes gère le modèle (GPT-5.5)
    -h|--help)    usage; exit 0;;
    --) shift; QUESTION="$QUESTION${QUESTION:+ }$*"; break;;
    *) QUESTION="$QUESTION${QUESTION:+ }$1"; shift;;
  esac
done

if [ -z "$QUESTION" ]; then usage; exit 1; fi

PROMPT=""
[ "$DEEP" = "1" ] && PROMPT="Analyse en profondeur, sois exhaustif et critique. "
if [ -n "$CONTEXT_FILE" ]; then
  [ -f "$CONTEXT_FILE" ] || { echo "Erreur: contexte introuvable: $CONTEXT_FILE" >&2; exit 1; }
  PROMPT="${PROMPT}Contexte fourni :
$(cat "$CONTEXT_FILE")

"
fi
PROMPT="${PROMPT}${QUESTION}"

B64=$(printf '%s' "$PROMPT" | base64 | tr -d '\n')
ssh -i "$KEY" -o BatchMode=yes -o ConnectTimeout=15 "$PVE" \
  "pct exec $CTID -- bash -c 'P=\$(printf %s $B64 | base64 -d); timeout 180 /usr/local/bin/hermes -z \"\$P\"'"
