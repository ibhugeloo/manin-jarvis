#!/bin/zsh
# jarvis — dispatcher manuel des routines
# Usage : jarvis <jour|hebdo|mensuel|veille|evaluation|watchtower|notion-sync> [args]
# Toutes les routines sont strictement manuelles depuis 2026-05-14.
# Aucun LaunchAgent ne déclenche plus claude — voir decisions.md.

set -uo pipefail

BIN="$HOME/.local/bin"
CMD="${1:-}"
shift || true

case "$CMD" in
  jour)
    exec "$BIN/jarvis-brief.sh" "$@"
    ;;
  hebdo|mensuel|veille|evaluation)
    exec "$BIN/jarvis-routine.sh" "$CMD" "$@"
    ;;
  watchtower)
    exec "$BIN/jarvis-watchtower.sh" "$@"
    ;;
  notion-sync)
    exec "$BIN/notion-export.sh" "$@"
    ;;
  finance)
    exec "$BIN/jarvis-finance.sh" "$@"
    ;;
  tech-watch)
    exec "$BIN/jarvis-tech-watch.sh" "$@"
    ;;
  memory-sync)
    exec "$BIN/jarvis-memory-sync.sh" "$@"
    ;;
  leo-sync)
    exec "$BIN/jarvis-leo-sync.sh" "$@"
    ;;
  status)
    exec "$BIN/jarvis-status" "$@"
    ;;
  -h|--help|help|"")
    cat <<'EOF'
jarvis — dispatcher manuel (aucune routine n'est plus automatique)

ROUTINES PRINCIPALES (consomment Anthropic)
  jarvis jour         — brief du jour (ex-brief matinal)
  jarvis hebdo        — revue de semaine
  jarvis mensuel      — bilan mensuel + audit Inbox Notion
  jarvis veille       — veille du jour
  jarvis evaluation   — auto-évaluation Jarvis

À LA DEMANDE
  jarvis watchtower   — surveillance prod clients (Sentry/Vercel/Supabase)
  jarvis notion-sync  — synchro Notion → vault (à lancer 1×/mois)
  jarvis finance      — analyse earnings portefeuille (votre broker)
  jarvis tech-watch   — veille agentic externe
  jarvis memory-sync  — backup Memory/ vers GitHub privé
  jarvis leo-sync     — récap Leo (Telegram, GPT-5.5) -> vault Brief/leo-feed.md (auto 23h)

UTILITAIRES (locaux)
  jarvis status       — inventaire projets GIT PROD/

Toutes les routines listées ci-dessus étaient des LaunchAgents auto avant 2026-05-14.
Désormais : exécution manuelle uniquement. Plists archivés dans
~/Library/LaunchAgents/disabled/.
EOF
    ;;
  *)
    echo "Commande inconnue : $CMD"
    echo "Voir : jarvis help"
    exit 1
    ;;
esac
