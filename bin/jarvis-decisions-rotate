#!/usr/bin/env python3
"""jarvis-decisions-rotate — archive les plus anciennes entrées de decisions.md.

Quand `decisions.md` dépasse un seuil de taille (default 35 KB), déplace les
entrées les plus anciennes vers `decisions-archive.md` jusqu'à repasser sous
le seuil. **Garde-fou** : ne touche jamais aux entrées du mois courant — on ne
veut pas archiver une décision prise il y a 3 jours juste parce que le fichier
dépasse temporairement.

Depuis 2026-05-09, `decisions.md` est en **format dense** (Décision + Pourquoi).
Le format long (Alternatives écartées + Conséquences acceptées) vit dans
`decisions-detail.md`. Pour chaque entrée rotée :
  1. Si une contrepartie longue existe dans `decisions-detail.md` (matching par
     heading H2 exact), elle est utilisée pour l'archive (préserve le pourquoi
     profond) et retirée de `decisions-detail.md`.
  2. Sinon, on archive la version dense en fallback (avec compteur reporté).

Idempotent : si déjà sous le seuil, no-op silencieux.

Usage :
  jarvis-decisions-rotate                       # threshold 35000, écriture
  jarvis-decisions-rotate --threshold 30000     # seuil custom
  jarvis-decisions-rotate --dry-run             # ne rien écrire, juste reporter
  jarvis-decisions-rotate --json                # output JSON pour orchestration

Conçu pour être invoqué par la routine `evaluation` (tous les 4j) ou
manuellement par le boss / Jarvis quand le warning Claude Code apparaît.
"""
from __future__ import annotations

import argparse
import json
import re
import sys
from datetime import date
from pathlib import Path

DECISIONS = Path.home() / "Documents/Obsidian/vault/Claude/Memory/decisions.md"
DETAIL = Path.home() / "Documents/Obsidian/vault/Claude/Memory/decisions-detail.md"
ARCHIVE = Path.home() / "Documents/Obsidian/vault/Claude/Memory/decisions-archive.md"
DEFAULT_THRESHOLD = 35_000

ENTRY_HEADING_RE = re.compile(r"^## (\d{4}-\d{2}-\d{2})", re.MULTILINE)


def _heading(block: str) -> str:
    """Première ligne H2 d'un block d'entrée (`## YYYY-MM-DD — title`)."""
    return block.split("\n", 1)[0].strip()


def parse_entries(text: str) -> tuple[str, list[tuple[str, str]]]:
    """Split text into (preamble, [(date_str, raw_block), ...]).

    raw_block includes the leading `## YYYY-MM-DD ...` heading and content
    up to (but not including) the next entry heading.
    """
    matches = list(ENTRY_HEADING_RE.finditer(text))
    if not matches:
        return text, []
    preamble = text[: matches[0].start()]
    entries: list[tuple[str, str]] = []
    for i, m in enumerate(matches):
        start = m.start()
        end = matches[i + 1].start() if i + 1 < len(matches) else len(text)
        entries.append((m.group(1), text[start:end]))
    return preamble, entries


def rotate(threshold: int, dry_run: bool) -> dict:
    if not DECISIONS.exists():
        return {"ok": False, "error": f"decisions.md introuvable : {DECISIONS}"}

    text = DECISIONS.read_text(encoding="utf-8")
    size_before = len(text)

    if size_before <= threshold:
        return {
            "ok": True,
            "rotated": 0,
            "size_before": size_before,
            "size_after": size_before,
            "threshold": threshold,
            "reason": f"under threshold ({size_before} ≤ {threshold})",
        }

    preamble, entries = parse_entries(text)
    if not entries:
        return {"ok": False, "error": "no entries detected (no `## YYYY-MM-DD` headings)"}

    current_month = date.today().strftime("%Y-%m")

    # Tri des entrées par date desc (plus récente en haut, plus ancienne en bas)
    entries_sorted = sorted(entries, key=lambda e: e[0], reverse=True)

    # Séparer mois courant (intouchables) vs candidats à rotation
    keep_current_month = [e for e in entries_sorted if e[0].startswith(current_month)]
    candidates = [e for e in entries_sorted if not e[0].startswith(current_month)]

    rotated: list[tuple[str, str]] = []

    # Drainer les candidats du plus ancien (queue) jusqu'à passer sous le seuil
    def _rebuild(remaining: list[tuple[str, str]]) -> str:
        return preamble + "".join(e[1] for e in keep_current_month + remaining)

    while candidates and len(_rebuild(candidates)) > threshold:
        rotated.append(candidates.pop())  # pop = plus ancien (queue de la liste sorted desc)

    if not rotated:
        return {
            "ok": True,
            "rotated": 0,
            "size_before": size_before,
            "size_after": size_before,
            "threshold": threshold,
            "reason": (
                "fichier au-dessus du seuil mais aucun candidat à rotation — "
                "toutes les entrées sont du mois courant ; consolider manuellement"
            ),
            "current_month_entries": len(keep_current_month),
        }

    new_decisions = _rebuild(candidates)

    # Pour chaque entrée rotée, chercher sa contrepartie longue dans decisions-detail.md
    # (même heading H2). Si trouvée, on utilise la version longue pour l'archive et on
    # marque l'entrée pour suppression de decisions-detail.md. Sinon fallback dense.
    detail_text = DETAIL.read_text(encoding="utf-8") if DETAIL.exists() else ""
    detail_preamble, detail_entries = parse_entries(detail_text) if detail_text else ("", [])

    archive_blocks: list[tuple[str, str]] = []  # (date, block to insert in archive)
    detail_remove_idx: set[int] = set()
    fallback_dense = 0

    for r_date, r_dense in rotated:
        r_head = _heading(r_dense)
        match_idx: int | None = None
        for idx, (d_date, d_block) in enumerate(detail_entries):
            if idx in detail_remove_idx:
                continue
            if d_date == r_date and _heading(d_block) == r_head:
                match_idx = idx
                break
        if match_idx is not None:
            archive_blocks.append((r_date, detail_entries[match_idx][1]))
            detail_remove_idx.add(match_idx)
        else:
            archive_blocks.append((r_date, r_dense))
            fallback_dense += 1

    # Construire le bloc rotated à insérer en tête de l'archive
    today_iso = date.today().isoformat()
    rotated_block = (
        f"\n<!-- Rotated {today_iso} from decisions.md "
        f"({len(archive_blocks)} entrée{'s' if len(archive_blocks) > 1 else ''}, "
        f"{archive_blocks[-1][0]} → {archive_blocks[0][0]}"
        f"{f', {fallback_dense} en fallback dense (pas de contrepartie longue)' if fallback_dense else ''})"
        " -->\n\n"
        + "".join(b for _, b in archive_blocks)
    )

    archive_text = ARCHIVE.read_text(encoding="utf-8") if ARCHIVE.exists() else "# Décisions structurantes — Archive\n\n"
    arch_preamble, arch_entries = parse_entries(archive_text)

    new_archive = arch_preamble + rotated_block + "".join(e[1] for e in arch_entries)

    new_detail = detail_preamble + "".join(
        b for idx, (_, b) in enumerate(detail_entries) if idx not in detail_remove_idx
    ) if detail_text else ""

    result = {
        "ok": True,
        "rotated": len(rotated),
        "rotated_dates": [e[0] for e in rotated],
        "size_before": size_before,
        "size_after": len(new_decisions),
        "archive_size_before": len(archive_text),
        "archive_size_after": len(new_archive),
        "detail_size_before": len(detail_text),
        "detail_size_after": len(new_detail),
        "detail_entries_removed": len(detail_remove_idx),
        "fallback_dense_count": fallback_dense,
        "threshold": threshold,
        "current_month_kept": len(keep_current_month),
        "non_current_kept": len(candidates),
        "dry_run": dry_run,
    }

    if not dry_run:
        DECISIONS.write_text(new_decisions, encoding="utf-8")
        ARCHIVE.write_text(new_archive, encoding="utf-8")
        if DETAIL.exists() and detail_remove_idx:
            DETAIL.write_text(new_detail, encoding="utf-8")

    return result


def main() -> int:
    p = argparse.ArgumentParser(description=__doc__.splitlines()[0])
    p.add_argument("--threshold", type=int, default=DEFAULT_THRESHOLD,
                   help=f"taille (chars) au-dessus de laquelle on rotate (default {DEFAULT_THRESHOLD})")
    p.add_argument("--dry-run", action="store_true", help="ne rien écrire, juste reporter")
    p.add_argument("--json", action="store_true", help="output JSON brut")
    args = p.parse_args()

    result = rotate(threshold=args.threshold, dry_run=args.dry_run)

    if args.json:
        print(json.dumps(result, indent=2, ensure_ascii=False))
        return 0 if result.get("ok") else 1

    if not result.get("ok"):
        print(f"❌ {result.get('error', 'unknown error')}", file=sys.stderr)
        return 1

    n = result.get("rotated", 0)
    if n == 0:
        reason = result.get("reason", "")
        print(f"✓ no rotation needed ({result['size_before']} chars, threshold {result['threshold']}) — {reason}")
        return 0

    prefix = "[DRY-RUN] " if args.dry_run else ""
    print(
        f"{prefix}↻ {n} entrée(s) rotated from decisions.md → decisions-archive.md"
    )
    print(f"  dates : {', '.join(result['rotated_dates'])}")
    print(f"  decisions  : {result['size_before']:,} → {result['size_after']:,} chars (threshold {result['threshold']:,})")
    print(f"  archive    : {result['archive_size_before']:,} → {result['archive_size_after']:,} chars")
    detail_removed = result.get("detail_entries_removed", 0)
    if detail_removed:
        print(f"  detail     : {result['detail_size_before']:,} → {result['detail_size_after']:,} chars ({detail_removed} entrée(s) extraite(s) en format long)")
    fallback = result.get("fallback_dense_count", 0)
    if fallback:
        print(f"  ⚠️  {fallback} entrée(s) sans contrepartie longue dans decisions-detail.md — archivées en format dense (fallback)")
    if args.dry_run:
        print("  (no files written — re-run without --dry-run to apply)")
    return 0


if __name__ == "__main__":
    sys.exit(main())
