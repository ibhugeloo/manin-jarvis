#!/usr/bin/env python3
"""jarvis-vault-index-build — régénère `_vault-index.md` à la racine du vault vault.

L'index liste toutes les notes du vault par dossier, avec leur titre H1 ou
nom de fichier. But : donner à Jarvis une carte du second cerveau auto-loadable
sans charger le contenu de 210+ notes.

**Exclusions** : `Brief/`, `Notion-Mirror/`, `Claude/Sessions/`, `_archives/`,
tout dossier commençant par `.`. Ces dossiers contiennent du contenu volumineux
ou éphémère qui n'a pas sa place dans un index permanent.

Idempotent : ré-exécutable autant qu'on veut. Écrit `_vault-index.md` à la racine
du vault, pas dans `Memory/` (l'index appartient au vault).

Usage :
  jarvis-vault-index-build             # écriture
  jarvis-vault-index-build --dry-run   # affiche, n'écrit pas

Conçu pour être appelé en début de `jarvis-brief.sh` (~7h30) ou manuellement
quand la structure du vault change significativement.
"""
from __future__ import annotations

import argparse
import re
import sys
from datetime import datetime
from pathlib import Path

VAULT = Path.home() / "Documents/Obsidian/vault"
INDEX_PATH = VAULT / "_vault-index.md"

EXCLUDE_DIR_NAMES = {
    "Brief",
    "Notion-Mirror",
    "Sessions",
    "_archives",
    "auto",
    "proposed",
    ".obsidian",
    ".git",
    ".trash",
}

# Sections "hub" prioritaires en tête de l'index ; tout le reste suit alphabétiquement
HUB_ORDER = [
    "Claude",
    "Holding",
    "Agency",
    "AgencyDev",
    "ShopApp",
    "ClientA",
    "Homelab",
    "Personnes",
    "Ressources",
]

H1_RE = re.compile(r"^#\s+(.+?)\s*$", re.MULTILINE)


def is_excluded(p: Path) -> bool:
    parts = p.relative_to(VAULT).parts
    return any(seg in EXCLUDE_DIR_NAMES or seg.startswith(".") for seg in parts)


def extract_title(md_path: Path) -> str:
    """Renvoie le titre H1 ou, à défaut, le nom de fichier sans extension."""
    try:
        text = md_path.read_text(encoding="utf-8", errors="ignore")
    except OSError:
        return md_path.stem
    # Sauter le frontmatter YAML s'il existe
    if text.startswith("---\n"):
        end = text.find("\n---\n", 4)
        if end != -1:
            text = text[end + 5 :]
    m = H1_RE.search(text)
    if m:
        return m.group(1).strip()
    return md_path.stem


def collect_notes() -> dict[str, list[tuple[str, str]]]:
    """Renvoie {dossier: [(filename, title), ...]} avec dossier='ROOT' pour racine."""
    by_dir: dict[str, list[tuple[str, str]]] = {}
    for md in VAULT.rglob("*.md"):
        if is_excluded(md):
            continue
        rel = md.relative_to(VAULT)
        bucket = "ROOT" if len(rel.parts) == 1 else rel.parts[0]
        title = extract_title(md)
        # Pour les sous-dossiers profonds, montrer le chemin relatif au bucket
        display_name = "/".join(rel.parts[1:]) if bucket != "ROOT" else rel.parts[0]
        by_dir.setdefault(bucket, []).append((display_name, title))
    for entries in by_dir.values():
        entries.sort(key=lambda x: x[0].lower())
    return by_dir


def render(by_dir: dict[str, list[tuple[str, str]]]) -> str:
    now = datetime.now().strftime("%Y-%m-%d %H:%M")
    total = sum(len(v) for v in by_dir.values())
    lines: list[str] = [
        "# Vault vault — index auto-régénéré",
        "",
        f"> Auto-généré par `jarvis-vault-index-build` le {now}.",
        f"> {total} notes indexées · {len(by_dir)} buckets.",
        "> **Ne pas éditer à la main** — vos changements seront écrasés. Pour le contenu manuel (hubs principaux, conventions), voir `_index.md`.",
        "",
        "Cet index donne la carte du second cerveau pour permettre à Jarvis de savoir *qu'une note existe* avant de chercher dedans. Il ne remplace pas la lecture — il pointe vers les bons fichiers.",
        "",
    ]

    # Hubs prioritaires d'abord, puis tout le reste alphabétique
    ordered_buckets = [b for b in HUB_ORDER if b in by_dir] + sorted(
        b for b in by_dir if b not in HUB_ORDER and b != "ROOT"
    )
    if "ROOT" in by_dir:
        ordered_buckets.append("ROOT")

    for bucket in ordered_buckets:
        entries = by_dir[bucket]
        section_title = "Racine du vault" if bucket == "ROOT" else f"{bucket}/"
        lines.append(f"## {section_title} ({len(entries)} note{'s' if len(entries) > 1 else ''})")
        lines.append("")
        for filename, title in entries:
            # Si le titre = le filename, ne pas le répéter
            stem = Path(filename).stem
            if title.lower() == stem.lower():
                lines.append(f"- `{filename}`")
            else:
                lines.append(f"- `{filename}` — {title}")
        lines.append("")

    return "\n".join(lines)


def main() -> int:
    p = argparse.ArgumentParser(description=__doc__.splitlines()[0])
    p.add_argument("--dry-run", action="store_true", help="affiche le contenu, n'écrit pas")
    args = p.parse_args()

    if not VAULT.exists():
        print(f"❌ vault introuvable : {VAULT}", file=sys.stderr)
        return 1

    by_dir = collect_notes()
    rendered = render(by_dir)

    if args.dry_run:
        print(rendered)
        return 0

    INDEX_PATH.write_text(rendered, encoding="utf-8")
    total = sum(len(v) for v in by_dir.values())
    size = len(rendered)
    print(f"✓ {INDEX_PATH.name} régénéré : {total} notes · {len(by_dir)} buckets · {size:,} chars")
    return 0


if __name__ == "__main__":
    sys.exit(main())
