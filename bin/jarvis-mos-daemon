#!/bin/zsh
# jarvis-mos-daemon — wrapper lancé par LaunchAgent com.example.jarvis.mos.
#
# Le wrapper EST copié dans ~/.local/bin/jarvis-mos-daemon (sans extension)
# par bootstrap.sh — c'est cette copie que la plist exécute (TCC-safe).
# Le code Python lui-même vit dans ~/.local/share/jarvis/lib/mos/ (déployé).
#
# Le daemon ne touche JAMAIS ~/Documents/ — TCC bloque l'accès depuis launchd.
# Le sync filesystem→DB se fait via `jarvis-mos sync` (shell utilisateur).
set -uo pipefail

LIB="$HOME/.local/share/jarvis/lib"
VENV="$HOME/.local/share/jarvis/venv"

[[ -d "$VENV" ]] || { echo "❌ venv missing: $VENV" >&2; exit 1; }
[[ -f "$LIB/mos/api.py" ]] || { echo "❌ mos/api.py missing: $LIB/mos/api.py" >&2; exit 1; }

cd "$LIB" || exit 1
export PYTHONPATH="$LIB${PYTHONPATH:+:$PYTHONPATH}"
export PYTHONUNBUFFERED=1

# Port centralisé via env var MOS_PORT. Défaut : 3737.
PORT="${MOS_PORT:-3737}"

exec "$VENV/bin/uvicorn" mos.api:app \
  --host 127.0.0.1 \
  --port "$PORT" \
  --log-level warning
