#!/bin/zsh
# jarvis-mos — CLI front pour Mission Operating System.
#
# Usage:
#   jarvis-mos status                    # health du daemon + counts
#   jarvis-mos list [open|wip|blocked|done|dropped]
#   jarvis-mos show <ID>                 # détail d'une mission
#   jarvis-mos sync                      # force resync filesystem→DB
#   jarvis-mos events [N]                # N derniers events (défaut 20)
#   jarvis-mos open <slug>               # crée share/missions/MOS-NNN-<slug>.md depuis _FORMAT.md
#
# Le daemon doit tourner sur 127.0.0.1:3000 (LaunchAgent com.example.jarvis.mos).

set -uo pipefail

API="${MOS_API:-http://127.0.0.1:${MOS_PORT:-3737}}"
REPO="$HOME/Documents/GIT PROD/manin-jarvis"
MISSIONS_DIR="$REPO/share/missions"
FORMAT_FILE="$MISSIONS_DIR/_FORMAT.md"

cmd="${1:-status}"
shift 2>/dev/null || true

_curl() {
  curl --silent --show-error --max-time 5 "$@"
}

_check_daemon() {
  if ! _curl "$API/health" >/dev/null 2>&1; then
    echo "❌ MOS daemon injoignable sur $API" >&2
    echo "   Lance : launchctl load ~/Library/LaunchAgents/com.example.jarvis.mos.plist" >&2
    exit 1
  fi
}

case "$cmd" in
  status)
    _check_daemon
    _curl "$API/health" | python3 -m json.tool
    ;;

  list)
    _check_daemon
    status_filter="${1:-}"
    if [[ -n "$status_filter" ]]; then
      url="$API/missions?status=$status_filter"
    else
      url="$API/missions"
    fi
    _curl "$url" | python3 -c "
import json, sys
d = json.load(sys.stdin)
for m in d.get('missions', []):
    print(f\"  {m['id']:<10} [{m['status']:<7}] {m['title']}\")
print(f\"\\n{d.get('count', 0)} missions\")
"
    ;;

  show)
    _check_daemon
    mid="${1:?ID requis (ex: MOS-001)}"
    _curl "$API/missions/$mid" | python3 -m json.tool
    ;;

  sync)
    # Local sync: read missions/*.md and write to DB directly.
    # Le CLI tourne dans le contexte user (Full Disk Access) — contrairement au daemon.
    VENV="$HOME/.local/share/jarvis/venv"
    LIB="$HOME/.local/share/jarvis/lib"
    if [[ ! -d "$VENV" ]]; then
      echo "❌ venv introuvable : $VENV" >&2
      exit 1
    fi
    PYTHONPATH="$LIB${PYTHONPATH:+:$PYTHONPATH}" "$VENV/bin/python" -c "
import json
from mos.db import connect
from mos.missions_md import sync_all
db = connect()
print(json.dumps(sync_all(db), indent=2))
"
    ;;

  events)
    _check_daemon
    n="${1:-20}"
    _curl "$API/events/recent?limit=$n" | python3 -c "
import json, sys
d = json.load(sys.stdin)
for e in d.get('events', []):
    tool = e.get('tool') or '-'
    print(f\"  {e['ts']}  {e['hook']:<18} {tool:<10} sid={e.get('session_id') or '-'}\")
print(f\"\\n{d.get('count', 0)} events\")
"
    ;;

  prune)
    # Local prune: delete events older than N days (default 90).
    # Tourne dans le contexte user (FDA) — accède directement à la DB.
    KEEP_DAYS="${1:-90}"
    VENV="$HOME/.local/share/jarvis/venv"
    LIB="$HOME/.local/share/jarvis/lib"
    if [[ ! -d "$VENV" ]]; then
      echo "❌ venv introuvable : $VENV" >&2
      exit 1
    fi
    PYTHONPATH="$LIB${PYTHONPATH:+:$PYTHONPATH}" "$VENV/bin/python" -c "
import json, sys
from mos.db import connect, prune_events
keep = int('$KEEP_DAYS')
db = connect()
print(json.dumps(prune_events(db, keep_days=keep), indent=2))
"
    ;;

  open)
    slug="${1:?slug requis (ex: brancher-watchtower-mos)}"
    last_num=$(ls "$MISSIONS_DIR" 2>/dev/null | grep -oE '^MOS-[0-9]+' | sort -t- -k2 -n | tail -1 | sed 's/MOS-0*//')
    last_num="${last_num:-0}"
    next_num=$((last_num + 1))
    new_id=$(printf "MOS-%03d" "$next_num")
    new_file="$MISSIONS_DIR/${new_id}-${slug}.md"
    if [[ -e "$new_file" ]]; then
      echo "❌ Existe déjà : $new_file" >&2
      exit 1
    fi
    today=$(date +%Y-%m-%d)
    cat > "$new_file" <<EOF
---
id: $new_id
title: $slug
status: open
opened_at: $today
closed_at:
deadline:
parent_dream:
deliverable: TODO — phrase qui prouve que c'est fait
tags: []
---

# $slug

## Pourquoi
TODO

## Définition de "done"
- [ ] TODO

## Plan
1. TODO

## Journal
- $today $(date +%H:%M) — Mission ouverte.

## Notes
EOF
    echo "✅ Créé : $new_file"
    if _curl "$API/health" >/dev/null 2>&1; then
      _curl -X POST "$API/sync" >/dev/null
      echo "   DB synchronisée."
    fi
    ;;

  help|-h|--help)
    sed -n '2,15p' "$0"
    ;;

  *)
    echo "❌ Commande inconnue : $cmd" >&2
    sed -n '2,15p' "$0" >&2
    exit 1
    ;;
esac
