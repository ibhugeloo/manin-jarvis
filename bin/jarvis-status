#!/bin/zsh
# jarvis-status — Vue groupe rapide de tous les repos GIT PROD.
# Usage : jarvis-status [--json]
#
# Sortie : pour chaque repo, branche, commits non pushés, modifs locales, dernier commit.
# Skip les dossiers qui ne sont pas des repos Git (cf. lessons.md #10).

set -uo pipefail

GIT_PROD="$HOME/Documents/GIT PROD"
# Dossiers à ignorer (projets abandonnés laissés "au cas où")
EXCLUDE_DIRS=(archives)

# Config catégorisation (filesystem flat, séparation logique)
REPOS_CONFIG="$HOME/Documents/GIT PROD/manin-jarvis/config/repos.yaml"

JSON_MODE=0
[[ "${1:-}" == "--json" ]] && JSON_MODE=1

is_excluded() {
  local name=$1
  for ex in "${EXCLUDE_DIRS[@]}"; do
    [[ "$name" == "$ex" ]] && return 0
  done
  return 1
}

# Retourne la catégorie d'un repo (lit le YAML via python)
repo_category() {
  local repo_name=$1
  /usr/bin/python3 -c "
import yaml, sys
try:
    cfg = yaml.safe_load(open('$REPOS_CONFIG'))
    name = sys.argv[1] if len(sys.argv) > 1 else '$repo_name'
    for cat, data in (cfg.get('categories') or {}).items():
        if name in (data.get('repos') or []):
            print(cat)
            sys.exit(0)
    print(cfg.get('default', 'perso'))
except Exception:
    print('perso')
" "$repo_name"
}

# Récupère le label affiché d'une catégorie
category_label() {
  local cat=$1
  /usr/bin/python3 -c "
import yaml
try:
    cfg = yaml.safe_load(open('$REPOS_CONFIG'))
    print((cfg.get('categories', {}).get('$cat', {}) or {}).get('label', '$cat'))
except Exception:
    print('$cat')
"
}

# Liste les catégories dans l'ordre déclaré
category_order() {
  /usr/bin/python3 -c "
import yaml
try:
    cfg = yaml.safe_load(open('$REPOS_CONFIG'))
    for cat in (cfg.get('categories') or {}).keys():
        print(cat)
except Exception:
    pass
"
}

if [[ ! -d "$GIT_PROD" ]]; then
  echo "❌ Dossier introuvable : $GIT_PROD" >&2
  exit 1
fi

# Couleurs (off si pipe ou --json)
if [[ -t 1 && "$JSON_MODE" -eq 0 ]]; then
  R=$'\033[31m'; G=$'\033[32m'; Y=$'\033[33m'; B=$'\033[34m'; D=$'\033[2m'; N=$'\033[0m'
else
  R=""; G=""; Y=""; B=""; D=""; N=""
fi

repos=()
for d in "$GIT_PROD"/*; do
  [[ -d "$d" ]] || continue
  is_excluded "$(basename "$d")" && continue
  # Cas standard : repo Git directement
  if (cd "$d" 2>/dev/null && git rev-parse --is-inside-work-tree >/dev/null 2>&1); then
    repos+=("$d")
    continue
  fi
  # Cas wrapper : pas un repo Git, mais peut contenir un repo enfant (cf. agency-app/agency-platform)
  for sub in "$d"/*; do
    [[ -d "$sub" ]] || continue
    if (cd "$sub" 2>/dev/null && git rev-parse --is-inside-work-tree >/dev/null 2>&1); then
      repos+=("$sub")
    fi
  done
done

if [[ ${#repos[@]} -eq 0 ]]; then
  echo "Aucun repo Git détecté dans $GIT_PROD" >&2
  exit 0
fi

# Fonction qui rend une ligne de repo (humain ou JSON)
render_repo() {
  local repo=$1
  local category=$2
  local first_in_json=$3  # 0 = premier, 1 = ajouter virgule devant

  # Nom d'affichage : si imbriqué dans un wrapper, garder le wrapper en préfixe
  rel_path="${repo#$GIT_PROD/}"
  if [[ "$rel_path" == */* ]]; then
    name="$rel_path"
  else
    name=$(basename "$repo")
  fi
  cd "$repo" || return

  branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null | head -1 | tr -d '\n\r' || echo "?")
  [[ -z "$branch" ]] && branch="?"
  modified=$(git status --porcelain 2>/dev/null | wc -l | tr -d ' \n')
  ahead=$( { git log @{u}..HEAD --oneline 2>/dev/null || true; } | wc -l | tr -d ' \n')
  last_commit=$(git log -1 --format='%cr' 2>/dev/null || echo "?")
  last_commit_iso=$(git log -1 --format='%cI' 2>/dev/null || echo "")
  [[ "$modified" =~ ^[0-9]+$ ]] || modified=0
  [[ "$ahead"    =~ ^[0-9]+$ ]] || ahead=0

  if [[ "$JSON_MODE" -eq 1 ]]; then
    [[ $first_in_json -eq 1 ]] && echo ","
    printf '  {"name":"%s","branch":"%s","modified":%s,"ahead":%s,"last_commit":"%s","last_commit_iso":"%s","category":"%s"}' \
      "$name" "$branch" "$modified" "$ahead" "$last_commit" "$last_commit_iso" "$category"
  else
    # Format humain
    status_color="$G"
    status_icon="✓"
    issues=()

    if [[ "$modified" -gt 0 ]]; then
      issues+=("${Y}${modified}${N} fichiers modifiés")
      status_color="$Y"
      status_icon="●"
    fi
    if [[ "$ahead" -gt 0 ]]; then
      issues+=("${Y}${ahead}${N} commits non pushés")
      status_color="$Y"
      status_icon="●"
    fi

    # Détecter inactivité > 30j
    if [[ -n "$last_commit_iso" ]]; then
      now_epoch=$(date +%s)
      commit_epoch=$(date -j -f "%Y-%m-%dT%H:%M:%S" "${last_commit_iso%%+*}" +%s 2>/dev/null || echo "$now_epoch")
      days_idle=$(( (now_epoch - commit_epoch) / 86400 ))
      if [[ "$days_idle" -gt 30 ]]; then
        issues+=("${R}${days_idle}j sans commit${N}")
        [[ "$status_color" == "$G" ]] && { status_color="$R"; status_icon="○"; }
      fi
    fi

    printf "${status_color}${status_icon}${N} ${B}%-25s${N} ${D}[%s]${N} ${D}— %s${N}\n" "$name" "$branch" "$last_commit"
    if [[ ${#issues[@]} -gt 0 ]]; then
      for issue in "${issues[@]}"; do
        printf "    %s\n" "$issue"
      done
    fi
  fi
}

# Construit une map repo_index → category (clé numérique pour éviter les
# soucis avec des espaces/slashes dans les paths zsh associative arrays)
declare -a REPO_CAT
for i in {1..${#repos[@]}}; do
  rel="${repos[$i]#$GIT_PROD/}"
  REPO_CAT[$i]=$(repo_category "$rel")
done

CATEGORIES=()
while IFS= read -r line; do CATEGORIES+=("$line"); done < <(category_order)

# Si pas de catégories trouvées (config absente/cassée), fallback à un seul groupe
if [[ ${#CATEGORIES[@]} -eq 0 ]]; then
  CATEGORIES=(perso)
fi

if [[ "$JSON_MODE" -eq 1 ]]; then
  echo "["
  json_first=0
  for cat in "${CATEGORIES[@]}"; do
    for i in {1..${#repos[@]}}; do
      [[ "${REPO_CAT[$i]:-perso}" == "$cat" ]] || continue
      render_repo "${repos[$i]}" "$cat" "$json_first"
      json_first=1
    done
  done
  echo ""
  echo "]"
else
  # Format humain : entête par catégorie
  for cat in "${CATEGORIES[@]}"; do
    cat_indices=()
    for i in {1..${#repos[@]}}; do
      [[ "${REPO_CAT[$i]:-perso}" == "$cat" ]] && cat_indices+=("$i")
    done
    [[ ${#cat_indices[@]} -eq 0 ]] && continue
    label=$(category_label "$cat")
    printf "\n${D}── %s ────────────────────────────────${N}\n" "$label"
    for i in "${cat_indices[@]}"; do
      render_repo "${repos[$i]}" "$cat" "0"
    done
  done
fi
