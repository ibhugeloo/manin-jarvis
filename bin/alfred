#!/usr/bin/env bash
# alfred — wrapper non-interactif pour invoquer Alfred, le majordome homelab du boss.
#
# Alfred = Claude Opus 4.7 avec un system prompt dédié homelab (alfred_project_instructions.md).
# `--system-prompt` remplace le prompt par défaut de Claude Code → la doctrine Jarvis n'est
# pas chargée, Alfred reste cantonné à son périmètre sysadmin / Proxmox / VLAN.
#
# Auth : OAuth / abo Claude Max du boss (pas de clé API consommée).
# Source canonique du system prompt : Obsidian/Homelab/alfred_project_instructions.md
# (override possible via ALFRED_PROMPT_FILE ou --prompt).

set -euo pipefail

ALFRED_PROMPT_FILE="${ALFRED_PROMPT_FILE:-$HOME/Documents/Obsidian/vault/Homelab/alfred_project_instructions.md}"
MODEL="${ALFRED_MODEL:-claude-opus-4-7}"
CONTEXT_FILE=""

usage() {
  cat <<'EOF'
alfred — majordome homelab du boss (Claude Opus 4.7, périmètre homelab strict)

Usage:
  alfred [OPTIONS] "<question>"

Options:
  -c, --context FILE   Injecte le contenu d'un fichier comme contexte additionnel
  -m, --model MODEL    Override du modèle Claude (défaut: claude-opus-4-7)
  -p, --prompt FILE    Override du system prompt (défaut: alfred_project_instructions.md)
  -h, --help           Affiche cette aide

Exemples:
  alfred "quel VMID prendre pour une nouvelle LXC sur VLAN 40 ?"
  alfred --context plan-migration.md "que faut-il vérifier avant de bouger PG Prod ?"

Variables d'env:
  ALFRED_PROMPT_FILE   Chemin du system prompt (override de --prompt)
  ALFRED_MODEL         Modèle Claude (override de --model)
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -c|--context)
      [[ $# -ge 2 ]] || { echo "Erreur: --context attend un fichier" >&2; exit 1; }
      CONTEXT_FILE="$2"; shift 2 ;;
    -m|--model)
      [[ $# -ge 2 ]] || { echo "Erreur: --model attend une valeur" >&2; exit 1; }
      MODEL="$2"; shift 2 ;;
    -p|--prompt)
      [[ $# -ge 2 ]] || { echo "Erreur: --prompt attend un fichier" >&2; exit 1; }
      ALFRED_PROMPT_FILE="$2"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    --) shift; break ;;
    -*) echo "Erreur: option inconnue: $1" >&2; usage >&2; exit 1 ;;
    *) break ;;
  esac
done

if [[ $# -lt 1 ]]; then
  echo "Erreur: question manquante." >&2
  usage >&2
  exit 1
fi

if [[ ! -f "$ALFRED_PROMPT_FILE" ]]; then
  echo "Erreur: system prompt Alfred introuvable: $ALFRED_PROMPT_FILE" >&2
  exit 1
fi

QUESTION="$*"
USER_INPUT="$QUESTION"
if [[ -n "$CONTEXT_FILE" ]]; then
  if [[ ! -f "$CONTEXT_FILE" ]]; then
    echo "Erreur: fichier contexte introuvable: $CONTEXT_FILE" >&2
    exit 1
  fi
  USER_INPUT="$(printf '%s\n\n--- CONTEXTE ---\n%s' "$QUESTION" "$(cat "$CONTEXT_FILE")")"
fi

claude -p \
  --model "$MODEL" \
  --system-prompt "$(cat "$ALFRED_PROMPT_FILE")" \
  --dangerously-skip-permissions \
  "$USER_INPUT"
