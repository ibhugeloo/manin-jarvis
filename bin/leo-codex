#!/usr/bin/env bash
# leo — wrapper non-interactif autour de Codex CLI pour obtenir un second avis
#        d'un modèle OpenAI (gpt-5.5 par défaut) via l'abo ChatGPT du boss.
#
# Usage:
#   leo "<question>"
#   leo --context FILE "<question>"
#   leo --deep "<question>"            # reasoning effort = high
#   leo --model gpt-5.5 "<question>"
#
# Auth : utilise ~/.codex/auth.json (login Codex CLI ou Codex.app).
# Sortie : uniquement la dernière réponse de l'agent, brute.

set -euo pipefail

LEO_PROMPT_FILE="${LEO_PROMPT_FILE:-$JARVIS_HOME/share/leo/system-prompt.md}"
CONTEXT_FILE=""
DEEP=0
MODEL="gpt-5.5"

usage() {
  cat <<'EOF'
leo — second avis via Codex CLI (modèle OpenAI, abo ChatGPT)

Usage:
  leo [OPTIONS] "<question>"

Options:
  -c, --context FILE   Injecte le contenu d'un fichier comme contexte
  -d, --deep           Reasoning effort = high (défaut: medium)
  -m, --model MODEL    Override du modèle (défaut: gpt-5.5)
  -h, --help           Affiche cette aide

Variables d'env:
  LEO_PROMPT_FILE      Chemin du system prompt Leo
                       (défaut: manin-jarvis/share/leo/system-prompt.md)

Exemples:
  leo "vaut-il mieux Postgres ou SQLite pour ce cas ?"
  leo --context docs/architecture.md "trouve les failles dans cette archi"
  leo --deep "analyse stratégique : passer Agency en SaaS ?"
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -c|--context)
      [[ $# -ge 2 ]] || { echo "Erreur: --context attend un fichier" >&2; exit 1; }
      CONTEXT_FILE="$2"
      shift 2
      ;;
    -d|--deep)
      DEEP=1
      shift
      ;;
    -m|--model)
      [[ $# -ge 2 ]] || { echo "Erreur: --model attend une valeur" >&2; exit 1; }
      MODEL="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo "Erreur: option inconnue: $1" >&2
      usage >&2
      exit 1
      ;;
    *)
      break
      ;;
  esac
done

if [[ $# -lt 1 ]]; then
  echo "Erreur: question manquante." >&2
  usage >&2
  exit 1
fi

QUESTION="$*"
EFFORT="medium"
[[ "$DEEP" -eq 1 ]] && EFFORT="high"

if [[ ! -f "$LEO_PROMPT_FILE" ]]; then
  echo "Erreur: system prompt Leo introuvable: $LEO_PROMPT_FILE" >&2
  exit 1
fi

SYSTEM_PROMPT="$(cat "$LEO_PROMPT_FILE")"

if [[ -n "$CONTEXT_FILE" ]]; then
  if [[ ! -f "$CONTEXT_FILE" ]]; then
    echo "Erreur: fichier contexte introuvable: $CONTEXT_FILE" >&2
    exit 1
  fi
  PROMPT="$(printf '%s\n\n=== QUESTION DU BOSS ===\n%s\n\n=== CONTEXTE INJECTÉ ===\n%s' \
    "$SYSTEM_PROMPT" "$QUESTION" "$(cat "$CONTEXT_FILE")")"
else
  PROMPT="$(printf '%s\n\n=== QUESTION DU BOSS ===\n%s' "$SYSTEM_PROMPT" "$QUESTION")"
fi

TMP_OUT="$(mktemp -t leo-out-XXXXXX)"
TMP_ERR="$(mktemp -t leo-err-XXXXXX)"
trap 'rm -f "$TMP_OUT" "$TMP_ERR"' EXIT

if ! codex exec \
    --skip-git-repo-check \
    --sandbox read-only \
    --ephemeral \
    --color never \
    --model "$MODEL" \
    -c "model_reasoning_effort=\"$EFFORT\"" \
    --output-last-message "$TMP_OUT" \
    "$PROMPT" </dev/null >/dev/null 2>"$TMP_ERR"; then
  echo "Erreur Codex (exit $?):" >&2
  cat "$TMP_ERR" >&2
  exit 1
fi

if [[ ! -s "$TMP_OUT" ]]; then
  echo "Erreur: Codex n'a pas produit de réponse." >&2
  cat "$TMP_ERR" >&2
  exit 1
fi

cat "$TMP_OUT"
echo
