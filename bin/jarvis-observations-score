#!/usr/bin/env python3
"""jarvis-observations-score — calcule un score 0-1 multi-facteur pour chaque entrée observations.md.

Inspiré du scoring OpenClaw 2026 (threshold 0.6 pour promotion vers MEMORY.md).

Formule :
  score = w1·confidence_prior + w2·spacing_bonus + w3·neg_signal_penalty + w4·explicit_validation

Avec :
- confidence_prior : high=0.7, medium=0.4, low=0.1 (poids w1=1.0)
- spacing_bonus    : +0.15 si pattern proche déjà observé sur ≥7 jours d'écart (w2=1.0)
- neg_signal_penalty : −0.30 si overlap ≥2 keywords avec _negative-signals.md (w3=1.0)
- explicit_validation : +0.15 si indices contiennent mots-clés validation forte
                        ("exactement", "très bien", "parfait", "OK", "valide")
                        (w4=1.0)

Le score est inscrit en frontmatter de chaque entrée : `score: 0.XX`.
Les entrées avec `status: PROMU/REJECTED/AUTO_PROMOTED/AUTO_APPLIED` sont skip.

Idempotent : ré-exécutable, met à jour le score si la formule change ou si négative signals évolue.

Usage :
  jarvis-observations-score             # met à jour observations.md (en place)
  jarvis-observations-score --dry-run   # affiche les scores calculés, n'écrit pas
"""
from __future__ import annotations

import argparse
import re
import sys
from datetime import date, datetime
from pathlib import Path

OBS = Path.home() / "Documents/Obsidian/vault/Claude/Memory/observations.md"
NEG = Path.home() / "Documents/Obsidian/vault/Claude/Memory/auto/_negative-signals.md"

# --- Heuristiques de détection ---
CONFIDENCE_PRIOR = {"high": 0.7, "medium": 0.4, "low": 0.1}
SPACING_BONUS = 0.15
NEG_PENALTY = 0.30
EXPLICIT_VAL_BONUS = 0.15
EXPLICIT_VAL_KEYWORDS = re.compile(
    r"\b(exactement|très bien|parfait|valid[ée]?|tout à fait|précis[ée]ment|c'est ça)\b",
    re.IGNORECASE,
)

ENTRY_RE = re.compile(
    r"---\s*\n(?P<frontmatter>(?:.*?\n)+?)---\s*\n(?P<body>.*?)(?=\n---\s*\n|\Z)",
    re.DOTALL,
)
DATE_RE = re.compile(r"^date:\s*(\d{4}-\d{2}-\d{2})", re.MULTILINE)
CONFIDENCE_RE = re.compile(r"^confidence:\s*(low|medium|high)", re.MULTILINE | re.IGNORECASE)
STATUS_RE = re.compile(r"^status:\s*(\S+)", re.MULTILINE)
SCORE_RE = re.compile(r"^score:\s*([\d.]+)\s*$", re.MULTILINE)


def load_negative_keywords() -> set[str]:
    """Charge les keywords de _negative-signals.md pour matching."""
    if not NEG.exists():
        return set()
    text = NEG.read_text(encoding="utf-8", errors="ignore")
    # Le fichier finit par une liste de keywords séparés par virgules après "## Keywords agrégés"
    m = re.search(r"## Keywords agrégés.*?\n\n(?:.*?\n)*?\n([a-zA-Zàâéèêëïîôöùûüç,\s]+)\Z", text, re.DOTALL)
    if not m:
        return set()
    return {w.strip() for w in m.group(1).split(",") if w.strip()}


def keyword_overlap(text: str, keywords: set[str]) -> int:
    """Renvoie le nombre de keywords présents dans text (lower)."""
    if not keywords:
        return 0
    text_low = text.lower()
    return sum(1 for kw in keywords if kw in text_low)


def compute_score(
    confidence: str,
    body: str,
    entry_date: str,
    all_dates: list[str],
    neg_keywords: set[str],
) -> tuple[float, dict]:
    """Renvoie (score_0_1, breakdown_dict)."""
    # Confidence prior
    conf_score = CONFIDENCE_PRIOR.get(confidence.lower(), 0.0)

    # Spacing bonus : pattern proche observé ≥7j d'écart
    spacing = 0.0
    if entry_date and all_dates:
        try:
            d = datetime.strptime(entry_date, "%Y-%m-%d").date()
            for other in all_dates:
                if other == entry_date:
                    continue
                try:
                    od = datetime.strptime(other, "%Y-%m-%d").date()
                    if abs((d - od).days) >= 7:
                        spacing = SPACING_BONUS
                        break
                except ValueError:
                    pass
        except ValueError:
            pass

    # Negative signal penalty
    overlap = keyword_overlap(body, neg_keywords)
    neg_pen = -NEG_PENALTY if overlap >= 2 else 0.0

    # Explicit validation bonus
    val_bonus = EXPLICIT_VAL_BONUS if EXPLICIT_VAL_KEYWORDS.search(body) else 0.0

    raw = conf_score + spacing + neg_pen + val_bonus
    score = max(0.0, min(1.0, raw))
    return score, {
        "confidence_prior": conf_score,
        "spacing_bonus": spacing,
        "neg_penalty": neg_pen,
        "explicit_validation": val_bonus,
        "raw": raw,
        "clamped": score,
    }


def process(text: str, dry_run: bool = False) -> tuple[str, list[dict]]:
    neg_keywords = load_negative_keywords()
    # Split par séparateurs `---` triple-line (frontmatter delim)
    # On garde le séparateur pour reconstruire fidèlement
    parts = re.split(r"(\n---\s*\n)", text)
    # Reconstruction par groupes de 4 : (body_before, sep, frontmatter_block, sep)
    # mais la structure réelle d'observations.md est plus libre. On fait robuste :
    # on collecte toutes les positions de séparateurs et on regroupe par paires.
    sep_positions: list[int] = []
    pos = 0
    for i, p in enumerate(parts):
        if p == "\n---\n" or p == "---\n":
            sep_positions.append(pos + len(parts[i - 1]) if i > 0 else pos)
        pos += len(p)

    # Approche plus simple : utiliser un split manuel ligne-par-ligne pour identifier
    # les blocs frontmatter (entre 2 `---` consécutifs)
    lines = text.split("\n")
    blocks: list[dict] = []  # {start_idx, end_idx, frontmatter, body_start, body_end}
    i = 0
    while i < len(lines):
        if lines[i].strip() == "---":
            # Frontmatter start, chercher la fin
            fm_start = i
            j = i + 1
            while j < len(lines) and lines[j].strip() != "---":
                j += 1
            if j < len(lines):
                fm_end = j  # ligne `---` fermante
                # Body : jusqu'au prochain `---` solitaire
                body_start = j + 1
                k = body_start
                while k < len(lines) and lines[k].strip() != "---":
                    k += 1
                body_end = k
                blocks.append({
                    "fm_start": fm_start,
                    "fm_end": fm_end,
                    "body_start": body_start,
                    "body_end": body_end,
                })
                i = body_end
            else:
                i += 1
        else:
            i += 1

    # Collect all dates first (pour spacing)
    all_dates: list[str] = []
    for b in blocks:
        fm_text = "\n".join(lines[b["fm_start"] + 1 : b["fm_end"]])
        d = DATE_RE.search(fm_text)
        if d:
            all_dates.append(d.group(1))

    breakdowns: list[dict] = []
    new_lines = list(lines)  # mutable copy

    for b in reversed(blocks):  # reverse pour préserver les indices lors de l'insertion
        fm_text = "\n".join(lines[b["fm_start"] + 1 : b["fm_end"]])
        body_text = "\n".join(lines[b["body_start"] : b["body_end"]])

        # Skip si déjà PROMU / REJECTED / AUTO_* (incl. AUTO_NOTED — pattern reconnu mais déjà couvert)
        status = STATUS_RE.search(fm_text)
        if status and status.group(1).upper() in {
            "PROMU", "REJECTED", "AUTO_PROMOTED", "AUTO_APPLIED", "AUTO_NOTED",
        }:
            continue

        conf = CONFIDENCE_RE.search(fm_text)
        if not conf:
            continue
        confidence = conf.group(1).lower()

        d = DATE_RE.search(fm_text)
        entry_date = d.group(1) if d else ""

        score, breakdown = compute_score(
            confidence=confidence,
            body=body_text,
            entry_date=entry_date,
            all_dates=all_dates,
            neg_keywords=neg_keywords,
        )
        breakdown["entry_date"] = entry_date
        breakdown["confidence"] = confidence
        breakdowns.append(breakdown)

        # Patch frontmatter : remplacer ou ajouter `score:`
        score_line = f"score: {score:.2f}"
        # Range des lignes frontmatter (exclusif `---`)
        fm_lines = new_lines[b["fm_start"] + 1 : b["fm_end"]]
        # Trouver une ligne `score:` existante
        replaced = False
        for li, line in enumerate(fm_lines):
            if SCORE_RE.match(line + "\n"):
                fm_lines[li] = score_line
                replaced = True
                break
        if not replaced:
            fm_lines.append(score_line)
        # Réinjecter
        new_lines[b["fm_start"] + 1 : b["fm_end"]] = fm_lines

    new_text = "\n".join(new_lines)
    if not dry_run:
        OBS.write_text(new_text, encoding="utf-8")
    return new_text, breakdowns


def main() -> int:
    p = argparse.ArgumentParser(description=__doc__.splitlines()[0])
    p.add_argument("--dry-run", action="store_true")
    args = p.parse_args()

    if not OBS.exists():
        print(f"⚠ observations.md introuvable : {OBS}", file=sys.stderr)
        return 1

    text = OBS.read_text(encoding="utf-8", errors="ignore")
    _, breakdowns = process(text, dry_run=args.dry_run)

    if not breakdowns:
        print("✓ Aucune entrée à scorer (toutes PROMU/REJECTED/AUTO_*).")
        return 0

    n_promote = sum(1 for b in breakdowns if b["clamped"] >= 0.6)
    print(f"✓ {len(breakdowns)} entrée(s) scorée(s) — {n_promote} ≥ 0.6 (candidates promotion).")
    if args.dry_run:
        print()
        for b in breakdowns:
            print(
                f"  {b['entry_date']} conf={b['confidence']:6} → "
                f"score={b['clamped']:.2f} "
                f"(prior={b['confidence_prior']:.2f} "
                f"spacing={b['spacing_bonus']:+.2f} "
                f"neg={b['neg_penalty']:+.2f} "
                f"val={b['explicit_validation']:+.2f})"
            )
        print("\n(--dry-run : observations.md non modifié)")
    return 0


if __name__ == "__main__":
    sys.exit(main())
