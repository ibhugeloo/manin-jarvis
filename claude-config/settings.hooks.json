{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/.local/bin/jarvis-hook-session-start.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/.local/bin/jarvis-hook-prompt-submit.sh"
          },
          {
            "type": "command",
            "command": "__HOME__/.local/bin/jarvis-context-watch.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/.local/bin/jarvis-session-recap.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/.local/bin/jarvis-memory-guard.sh"
          }
        ]
      }
    ]
  }
}
